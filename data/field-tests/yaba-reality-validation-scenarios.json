{
  "version": "2026-05-21",
  "pilotZone": "Yaba, Lagos",
  "purpose": "Validate controlled reality experiments, observed-vs-assumed divergence, human chaos, fatigue, and false-confidence resistance.",
  "scenarios": [
    {
      "id": "unsafe-uncontrolled-experiment",
      "name": "Unsupervised live experiment is blocked",
      "input": {
        "experiment": {
          "supervisorAssigned": false,
          "rollbackAuthorityAssigned": false,
          "auditTrailEnabled": false,
          "participantConsentRecorded": false,
          "maxParticipants": 120,
          "durationHours": 8,
          "incidentCategories": ["medical", "violent-crime"],
          "liveDispatchEnabled": true,
          "manualApprovalRequired": false
        }
      },
      "expectedDecision": "do-not-run-or-stop-experiment"
    },
    {
      "id": "observed-reality-breaks-assumptions",
      "name": "Observed field behavior overrides simulated confidence",
