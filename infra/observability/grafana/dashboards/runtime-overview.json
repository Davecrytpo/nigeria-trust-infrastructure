{
  "title": "Nigeria Trust Runtime Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "stat",
      "title": "Redis Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "redis_up", "legendFormat": "redis" }]
    },
    {
      "type": "stat",
      "title": "Postgres Up",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "pg_up", "legendFormat": "postgres" }]
    },
    {
      "type": "timeseries",
      "title": "Redis Commands",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "commands/sec" }]
    },
    {
      "type": "timeseries",
      "title": "Postgres Connections",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "{{state}}" }]
    }
  ]
}
