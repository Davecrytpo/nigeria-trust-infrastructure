{
  "name": "nigeria-trust-infrastructure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run start --workspace=services/api",
    "start": "npm run start --workspace=services/api",
    "start:poc": "node services/api-prototype/src/server.js",
    "field:test": "node scripts/field-tests/run-field-drills.js",
    "field:stress": "node scripts/field-tests/run-field-drills.js data/field-tests/yaba-operational-stress-scenarios.json",
    "field:convergence": "node scripts/field-tests/run-convergence-drills.js",
    "field:adaptive": "node scripts/field-tests/run-adaptive-resilience-drills.js",
    "field:maturity": "node scripts/field-tests/run-strategic-maturity-drills.js",
    "field:governance": "node scripts/field-tests/run-civic-governance-drills.js",
    "field:pilot": "node scripts/field-tests/run-limited-pilot-drills.js",
    "field:certify": "node scripts/field-tests/run-precertification-drills.js",
    "field:reality": "node scripts/field-tests/run-reality-validation-drills.js",
    "field:memory": "node scripts/field-tests/run-operational-memory-drills.js",
    "field:epistemic": "node scripts/field-tests/run-epistemic-resilience-drills.js",
    "field:live": "node scripts/field-tests/run-live-operationalization-drills.js",
    "field:evolution": "node scripts/field-tests/run-field-evolution-drills.js",
    "field:legibility": "node scripts/field-tests/run-civic-legibility-drills.js",
    "field:integrity": "node scripts/field-tests/run-civic-integrity-drills.js",
    "field:sustainability": "node scripts/field-tests/run-civic-sustainability-drills.js",
    "field:legitimacy": "node scripts/field-tests/run-adaptive-legitimacy-drills.js",
    "field:civilization": "node scripts/field-tests/run-civilizational-stability-drills.js",
    "field:existential": "node scripts/field-tests/run-existential-safety-drills.js",
    "db:migrate": "node scripts/db/migrate.js",
    "db:seed": "node scripts/db/seed-operational-data.js",
    "worker:delivery": "node scripts/workers/delivery-worker.js",
    "worker:replay": "node scripts/workers/replay-worker.js",
    "worker:operator-queue": "node scripts/workers/operator-queue-worker.js",
    "worker:trust-quarantine": "node scripts/workers/trust-quarantine-worker.js",
    "worker:escalation": "node scripts/workers/escalation-worker.js",
    "worker:dead-letter-replay": "node scripts/workers/dead-letter-replay-worker.js",
    "recovery:redis": "node scripts/recovery/rebuild-redis-from-postgres.js",
    "backup:postgres": "sh scripts/recovery/backup-postgres.sh",
    "restore:postgres": "sh scripts/recovery/restore-postgres.sh",
    "prod:preflight": "sh scripts/host/preflight-linux-vps.sh",
    "prod:env:validate": "node scripts/host/validate-production-env.js",
    "telecom:validate-live": "node scripts/telecom/live-provider-validation.js",
    "security:audit": "node scripts/security/audit-controls.js",
    "runtime:validate": "node scripts/integration/live-runtime-validation.js",
    "runtime:failure-drills": "node scripts/integration/failure-drills.js",
    "evidence:package": "node scripts/integration/package-evidence.js",
    "evidence:hash": "node scripts/integration/hash-evidence.js",
    "mobile:capture-validation": "node scripts/mobile/capture-device-validation.js",
    "mobile:setup:print": "powershell -ExecutionPolicy Bypass -File scripts/mobile/print-low-spec-android-setup.ps1",
    "mobile:toolchain": "powershell -ExecutionPolicy Bypass -File scripts/mobile/check-android-toolchain.ps1",
    "mobile:usb-apk": "powershell -ExecutionPolicy Bypass -File scripts/mobile/build-usb-apk.ps1",
    "mobile:usb-apk:fast": "powershell -ExecutionPolicy Bypass -File scripts/mobile/build-usb-apk.ps1 -Mode debug -Install -SkipTests",
    "mobile:usb-apk:profile": "powershell -ExecutionPolicy Bypass -File scripts/mobile/build-usb-apk.ps1 -Mode profile -Install -SkipTests",
    "mobile:usb-apk:release": "powershell -ExecutionPolicy Bypass -File scripts/mobile/build-usb-apk.ps1 -Mode release",
    "mobile:usb-apk:size": "powershell -ExecutionPolicy Bypass -File scripts/mobile/build-usb-apk.ps1 -Mode release -AnalyzeSize -SkipTests",
    "test": "node --test services/api-prototype/src/server.test.js services/api-prototype/src/adversarial.test.js"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
